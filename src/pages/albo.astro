---
import MkcLayout from '../layouts/MkcLayout.astro';
---

<MkcLayout title="Albo d'Oro | Matenano Kings Cup">
  {/* SFONDO TOTAL BLACK CON SHOCKWAVE DI LUCI DORATE COERENTE CON LA HOME */}
  <main class="py-16 bg-[#030302] min-h-screen text-white px-4 relative overflow-hidden">
    
    {/* LIVELLO SPRAZZI ORO MULTIPLI CON EFFETTO FADE-IN CONTINUO (Importato dalla Home) */}
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
      
      {/* 1. LAMA DI LUCE ORO ROTANTE VELOCE */}
      <div 
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[220%] h-[450px] opacity-45 mix-blend-color-dodge animate-[spin_8s_linear_infinite]"
        style="background: linear-gradient(135deg, transparent 40%, rgba(255,234,0,0.8) 50%, transparent 60%); filter: blur(55px);"
      ></div>

      {/* 2. SECONDA LAMA CONTRO-ROTANTE VELOCIZZATA */}
      <div 
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[200%] h-[350px] opacity-35 mix-blend-color-dodge animate-[spin_12s_linear_infinite]"
        style="background: linear-gradient(45deg, transparent 42%, rgba(212,175,55,0.7) 50%, transparent 58%); filter: blur(45px); animation-direction: reverse;"
      ></div>

      {/* 3. SPRAZZO IN ALTO A SINISTRA */}
      <div 
        class="absolute w-[650px] h-[650px] rounded-full mix-blend-color-dodge animate-[pulse_2.5s_ease-in-out_infinite]"
        style="top: -20%; left: -15%; background: radial-gradient(circle, rgba(255,234,0,0.3) 0%, rgba(212,175,55,0.08) 40%, transparent 70%);"
      ></div>

      {/* 4. SPRAZZO IN BASSO A DESTRA */}
      <div 
        class="absolute w-[650px] h-[650px] rounded-full mix-blend-color-dodge animate-[pulse_3s_ease-in-out_infinite]"
        style="bottom: -20%; right: -15%; background: radial-gradient(circle, rgba(255,215,0,0.25) 0%, rgba(234,179,8,0.05) 45%, transparent 70%); animation-delay: 1s;"
      ></div>

      {/* 5. FARO LATERALE AD ALTA VELOCITÀ */}
      <div 
        class="absolute w-[500px] h-[500px] rounded-full mix-blend-screen opacity-40 animate-[bounce_5s_infinite]"
        style="top: 25%; right: -10%; background: radial-gradient(circle, rgba(255,234,0,0.3) 0%, transparent 65%); filter: blur(30px);"
      ></div>

      {/* 6. SPRAZZO IN ALTO A DESTRA */}
      <div 
        class="absolute w-[450px] h-[450px] rounded-full mix-blend-color-dodge animate-[pulse_2s_ease-in-out_infinite]"
        style="top: -10%; right: -5%; background: radial-gradient(circle, rgba(250,204,21,0.2) 0%, transparent 65%); animation-delay: 0.5s;"
      ></div>

      {/* 7. SPRAZZO IN BASSO A SINISTRA */}
      <div 
        class="absolute w-[450px] h-[450px] rounded-full mix-blend-screen animate-[pulse_3.5s_ease-in-out_infinite]"
        style="bottom: -10%; left: -5%; background: radial-gradient(circle, rgba(234,179,8,0.18) 0%, transparent 65%); animation-delay: 1.5s;"
      ></div>

      {/* 8. BAGLIORE CENTRALE DI SFONDO */}
      <div 
        class="absolute top-[20%] left-[15%] w-[650px] h-[650px] rounded-full mix-blend-screen animate-[pulse_4s_ease-in-out_infinite]"
        style="background: radial-gradient(circle, rgba(255,234,0,0.15) 0%, transparent 60%); filter: blur(40px); animation-delay: 0.7s;"
      ></div>

      {/* STRUTTURA GEOMETRICA DI RIFRAZIONE ACCESA */}
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,234,0,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,234,0,0.03)_1px,transparent_1px)] bg-[size:30px_30px]"></div>
    </div>

    {/* CONTENUTO CENTRATO */}
    <div class="max-w-7xl mx-auto space-y-16 relative z-10">
      
      {/* INTESTAZIONE PAGINA */}
      <div class="text-center space-y-4 pt-4">
        <span class="font-mono text-xs uppercase tracking-widest text-[#ffea00]/80 font-bold bg-[#ffea00]/10 px-3 py-1 rounded-full inline-block">
          Edizione 2025
        </span>
        <h1 class="text-regale block leading-none">
          <span class="block text-4xl md:text-6xl text-shine-silver-gold tracking-[0.05em] font-bold pb-2">
            Albo d'Oro
          </span>
        </h1>
        <div class="w-24 h-1 bg-[#ffea00] mx-auto mt-4"></div>
      </div>

      {/* --- SEZIONE PODIO SQUADRE --- */}
      <div class="space-y-12">
        <div class="text-center">
          <h2 class="text-xs md:text-sm font-mono uppercase tracking-[0.3em] text-[#d4af37] font-bold">
            Il Podio delle Squadre
          </h2>
        </div>

        {/* STRUTTURA PODIO: Ordinata visivamente per importanza (2° - 1° - 3°) su Desktop */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-end max-w-5xl mx-auto pt-6">
          
          {/* 2° CLASSIFICATO: SIGMA */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6 text-center space-y-4 order-2 md:order-1 hover:border-white/30 transition-all relative overflow-hidden group min-h-[240px] flex flex-col justify-center">
            {/* Logo di Sfondo Centrato e Tagliato - Ingrandito per bilanciamento ottico */}
            <img 
              src="/assets/sigma.png" 
              alt="" 
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 object-contain opacity-[0.14] mix-blend-luminosity pointer-events-none group-hover:scale-110 transition-transform duration-700 z-0"
            />
            
            <div class="relative z-10 space-y-4">
              <div class="inline-block px-4 py-1 rounded-full bg-white/5 border border-white/10 font-mono text-xs text-white/70 uppercase tracking-widest">
                2° Posto
              </div>
              <h3 class="text-3xl font-display font-black uppercase tracking-wider text-white">
                Sigma
              </h3>
              <p class="text-xs font-mono text-white/50 uppercase tracking-wider">Medaglia d'Argento</p>
            </div>
          </div>

          {/* 1° CLASSIFICATO - CAMPIONE: SOLD OUT */}
          <div class="bg-black/50 backdrop-blur-xl border-2 border-[#ffea00]/50 rounded-2xl p-6 md:p-8 text-center order-1 md:order-2 shadow-[0_0_50px_rgba(255,234,0,0.25)] relative transform md:-translate-y-4 hover:border-[#ffea00] transition-all group overflow-hidden min-h-[260px] md:min-h-[300px] flex flex-col justify-center">
            
            {/* Logo di Sfondo Potenziato: Colori vividi e opacità aumentata */}
            <img 
              src="/assets/soldout.png" 
              alt="" 
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 object-contain opacity-30 pointer-events-none group-hover:opacity-45 group-hover:rotate-3 transition-all duration-700 z-0"
            />

            {/* Corona Badge */}
            <div class="absolute -top-5 left-1/2 -translate-x-1/2 bg-[#ffea00] text-black text-xs font-mono font-black uppercase tracking-widest px-5 py-1.5 rounded-full shadow-lg z-20 animate-pulse">
               Campioni 
            </div>

            {/* Testo Principale con animazione oro cangiante uguale al titolo */}
            <div class="space-y-3 pt-4 relative z-10">
              <h3 class="text-5xl md:text-6xl font-display font-black uppercase tracking-widest text-shine-silver-gold pb-1 drop-shadow-[0_4px_12px_rgba(0,0,0,0.5)]">
                Sold Out
              </h3>
              <div class="w-12 h-[2px] bg-[#ffea00]/60 mx-auto"></div>
              <p class="text-xs font-mono uppercase tracking-[0.2em] text-[#ffea00] font-bold">
                Vincitore Prima Edizione
              </p>
            </div>
          </div>

          {/* 3° CLASSIFICATO: PUNTO PIZZA */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6 text-center space-y-4 order-3 hover:border-white/30 transition-all relative overflow-hidden group min-h-[240px] flex flex-col justify-center">
            {/* Logo di Sfondo Centrato e Tagliato - Ridimensionato per bilanciamento ottico con Sigma */}
            <img 
              src="/assets/puntopizza.png" 
              alt="" 
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-52 h-52 object-contain opacity-[0.12] mix-blend-luminosity pointer-events-none group-hover:scale-110 transition-transform duration-700 z-0"
            />

            <div class="relative z-10 space-y-4">
              <div class="inline-block px-4 py-1 rounded-full bg-white/5 border border-white/10 font-mono text-xs text-white/70 uppercase tracking-widest">
                3° Posto
              </div>
              <h3 class="text-3xl font-display font-black uppercase tracking-wider text-white">
                Punto Pizza
              </h3>
              <p class="text-xs font-mono text-white/50 uppercase tracking-wider">Medaglia di Bronzo</p>
            </div>
          </div>

        </div>
      </div>

      <hr class="border-white/5 max-w-xl mx-auto" />

      {/* --- SEZIONE PREMI PERSONALI --- */}
      <div class="space-y-10">
        <div class="text-center">
          <h2 class="text-xs md:text-sm font-mono uppercase tracking-[0.3em] text-[#d4af37] font-bold">
            Premi Individuali
          </h2>
        </div>

        {/* GRID DEI PREMI PERSONALI (5 COLONNE SU SCHERMI GRANDI) */}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-7xl mx-auto">
          
          {/* PREMIO: MIGLIOR GIOCATORE */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/5 rounded-2xl p-5 text-center space-y-4 hover:border-[#ffea00]/40 transition-all shadow-xl group">
            <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mx-auto border border-white/10 group-hover:border-[#ffea00]/30 transition-all duration-300 p-2">
              <img src="/assets/soldout.png" alt="Sold Out Logo" class="w-full h-full object-contain" />
            </div>
            <div class="space-y-1">
              <h3 class="text-[10px] font-mono uppercase tracking-widest text-white/50">Miglior Giocatore</h3>
              <p class="text-base font-display font-black uppercase text-[#ffea00] tracking-wide line-clamp-1">
                Mattia Bruni
              </p>
              <p class="text-xs font-mono text-white/70">Sold Out</p>
            </div>
          </div>

          {/* PREMIO: CAPOCANNONIERE */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/5 rounded-2xl p-5 text-center space-y-4 hover:border-[#ffea00]/40 transition-all shadow-xl group">
            <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mx-auto border border-white/10 group-hover:border-[#ffea00]/30 transition-all duration-300 p-2">
              <img src="/assets/soldout.png" alt="Sold Out Logo" class="w-full h-full object-contain" />
            </div>
            <div class="space-y-1">
              <h3 class="text-[10px] font-mono uppercase tracking-widest text-white/50">Capocannoniere</h3>
              <p class="text-base font-display font-black uppercase text-[#ffea00] tracking-wide line-clamp-1">
                Thomas Tidei
              </p>
              <p class="text-xs font-mono text-white/70">Sold Out</p>
            </div>
          </div>

          {/* PREMIO: MIGLIOR PORTIERE */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/5 rounded-2xl p-5 text-center space-y-4 hover:border-[#ffea00]/40 transition-all shadow-xl group">
            <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mx-auto border border-white/10 group-hover:border-[#ffea00]/30 transition-all duration-300 p-2">
              <img src="/assets/sigma.png" alt="Sigma Logo" class="w-full h-full object-contain" />
            </div>
            <div class="space-y-1">
              <h3 class="text-[10px] font-mono uppercase tracking-widest text-white/50">Miglior Portiere</h3>
              <p class="text-base font-display font-black uppercase text-[#ffea00] tracking-wide line-clamp-1">
                Paolo Mercuri
              </p>
              <p class="text-xs font-mono text-white/70">Sigma</p>
            </div>
          </div>

          {/* PREMIO: MIGLIOR GOL */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/5 rounded-2xl p-5 text-center space-y-4 hover:border-[#ffea00]/40 transition-all shadow-xl group">
            <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mx-auto border border-white/10 group-hover:border-[#ffea00]/30 transition-all duration-300 p-2">
              <img src="/assets/soldout.png" alt="Sold Out Logo" class="w-full h-full object-contain" />
            </div>
            <div class="space-y-1">
              <h3 class="text-[10px] font-mono uppercase tracking-widest text-white/50">Miglior Gol</h3>
              <p class="text-base font-display font-black uppercase text-[#ffea00] tracking-wide line-clamp-1">
                Emilio Sacconi
              </p>
              <p class="text-xs font-mono text-white/70">Sold Out</p>
            </div>
          </div>

          {/* PREMIO: MIGLIOR PRESIDENTE */}
          <div class="bg-black/40 backdrop-blur-xl border border-white/5 rounded-2xl p-5 text-center space-y-4 hover:border-[#ffea00]/40 transition-all shadow-xl group">
            <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mx-auto border border-white/10 group-hover:border-[#ffea00]/30 transition-all duration-300 p-2">
              <img src="/assets/soldout.png" alt="Sold Out Logo" class="w-full h-full object-contain" />
            </div>
            <div class="space-y-1">
              <h3 class="text-[10px] font-mono uppercase tracking-widest text-white/50">Miglior Presidente</h3>
              <p class="text-base font-display font-black uppercase text-[#ffea00] tracking-wide line-clamp-1">
                Alex Marini
              </p>
              <p class="text-xs font-mono text-white/70">Sold Out</p>
            </div>
          </div>

        </div>
      </div>

      {/* BOTTONE DI RITORNO ALLA HOME */}
      <div class="text-center pt-4">
        <a 
          href="/" 
          class="inline-block px-10 py-4 bg-black/40 backdrop-blur-sm border border-white/10 text-white font-mono text-xs uppercase tracking-widest rounded-full hover:border-[#ffea00] hover:text-[#ffea00] hover:bg-[#ffea00]/5 transition-all"
        >
          ← Torna alla Home
        </a>
      </div>

    </div>
  </main>
</MkcLayout>

<style is:inline>
  /* Importazione del font Spectral SC coerente con l'estetica della index */
  @import url('https://fonts.googleapis.com/css2?family=Spectral+SC:wght=700;800&display=swap');

  .text-regale {
    font-family: 'Spectral SC', Georgia, serif;
  }

  @keyframes shine {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .text-shine-silver-gold {
    background: linear-gradient(
      110deg,
      #d4af37 10%,
      #e5e7eb 30%,
      #ffffff 50%,
      #e5e7eb 70%,
      #d4af37 90%
    );
    background-size: 200% auto;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shine 6s linear infinite;
  }
</style>