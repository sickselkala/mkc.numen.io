---
import MkcLayout from '../layouts/MkcLayout.astro';
---

<MkcLayout title="Home | Matenano Kings Cup">
  {/* SFONDO TOTAL BLACK CON SHOCKWAVE DI LUCI DORATE MORBIDE MA VELOCI */}
  <main class="py-16 bg-[#030302] min-h-screen text-white px-4 relative overflow-hidden">
    
    {/* LIVELLO SPRAZZI ORO MULTIPLI CON EFFETTO FADE-IN CONTINUO */}
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
      
      {/* 1. LAMA DI LUCE ORO ROTANTE VELOCE */}
      <div 
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[220%] h-[450px] opacity-45 mix-blend-color-dodge animate-[spin_8s_linear_infinite]"
        style="background: linear-gradient(135deg, transparent 40%, rgba(255,234,0,0.8) 50%, transparent 60%); filter: blur(55px);"
      ></div>

      {/* 2. SECONDA LAMA CONTRO-ROTANTE VELOCIZZATA */}
      <div 
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[200%] h-[350px] opacity-35 mix-blend-color-dodge animate-[spin_12s_linear_infinite]"
        style="background: linear-gradient(45deg, transparent 42%, rgba(212,175,55,0.7) 50%, transparent 58%); filter: blur(45px); animation-direction: reverse;"
      ></div>

      {/* 3. SPRAZZO IN ALTO A SINISTRA */}
      <div 
        class="absolute w-[650px] h-[650px] rounded-full mix-blend-color-dodge animate-[pulse_2.5s_ease-in-out_infinite]"
        style="
          top: -20%;
          left: -15%;
          background: radial-gradient(circle, rgba(255,234,0,0.3) 0%, rgba(212,175,55,0.08) 40%, transparent 70%);
        "
      ></div>

      {/* 4. SPRAZZO IN BASSO A DESTRA */}
      <div 
        class="absolute w-[650px] h-[650px] rounded-full mix-blend-color-dodge animate-[pulse_3s_ease-in-out_infinite]"
        style="
          bottom: -20%;
          right: -15%;
          background: radial-gradient(circle, rgba(255,215,0,0.25) 0%, rgba(234,179,8,0.05) 45%, transparent 70%);
          animation-delay: 1s;
        "
      ></div>

      {/* 5. FARO LATERALE AD ALTA VELOCITÀ */}
      <div 
        class="absolute w-[500px] h-[500px] rounded-full mix-blend-screen opacity-40 animate-[bounce_5s_infinite]"
        style="
          top: 25%;
          right: -10%;
          background: radial-gradient(circle, rgba(255,234,0,0.3) 0%, transparent 65%);
          filter: blur(30px);
        "
      ></div>

      {/* 6. SPRAZZO IN ALTO A DESTRA */}
      <div 
        class="absolute w-[450px] h-[450px] rounded-full mix-blend-color-dodge animate-[pulse_2s_ease-in-out_infinite]"
        style="
          top: -10%;
          right: -5%;
          background: radial-gradient(circle, rgba(250,204,21,0.2) 0%, transparent 65%);
          animation-delay: 0.5s;
        "
      ></div>

      {/* 7. SPRAZZO IN BASSO A SINISTRA */}
      <div 
        class="absolute w-[450px] h-[450px] rounded-full mix-blend-screen animate-[pulse_3.5s_ease-in-out_infinite]"
        style="
          bottom: -10%;
          left: -5%;
          background: radial-gradient(circle, rgba(234,179,8,0.18) 0%, transparent 65%);
          animation-delay: 1.5s;
        "
      ></div>

      {/* 8. BAGLIORE CENTRALE DI SFONDO */}
      <div 
        class="absolute top-[20%] left-[15%] w-[650px] h-[650px] rounded-full mix-blend-screen animate-[pulse_4s_ease-in-out_infinite]"
        style="
          background: radial-gradient(circle, rgba(255,234,0,0.15) 0%, transparent 60%);
          filter: blur(40px);
          animation-delay: 0.7s;
        "
      ></div>

      {/* STRUTTURA GEOMETRICA DI RIFRAZIONE ACCESA */}
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,234,0,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,234,0,0.03)_1px,transparent_1px)] bg-[size:30px_30px]"></div>
    </div>

    {/* CONTENUTO CENTRATO */}
    <div class="max-w-7xl mx-auto space-y-12 relative z-10">
      
      {/* SEZIONE LOGO PRINCIPALE E TITOLO */}
      <div class="flex flex-col items-center justify-center pt-8 text-center space-y-6">
        <div class="relative group">
          {/* Alone giallo morbido dietro l'immagine */}
          <div class="absolute inset-0 bg-[#ffea00]/30 blur-[45px] rounded-full opacity-70 group-hover:opacity-100 group-hover:blur-[35px] transition-all duration-500"></div>
          
          <img 
            src="/assets/mkc26.png" 
            alt="Matenano Kings Cup 2026"
            class="w-40 md:w-56 h-auto object-contain filter drop-shadow-[0_15px_30px_rgba(0,0,0,0.95)] relative z-10"
          />
        </div>

        {/* DESCRIZIONE E ANTEPRIMA TESTO */}
        <div class="max-w-4xl mx-auto px-4 pt-2 text-center flex flex-col items-center">
          
          {/* TITOLO SPEZZATO CORRETTAMENTE */}
          <h1 class="text-regale block py-2 leading-none">
            <span class="block w-full text-3xl md:text-5xl lg:text-6xl text-shine-silver-gold tracking-[0.05em] font-bold pb-4">
              Chi vuole essere il
            </span>
            <span class="block w-full text-7xl md:text-9xl lg:text-[10rem] text-shine-re tracking-[0.02em] font-extrabold filter drop-shadow-[0_0_50px_rgba(255,234,0,0.7)] pt-2">
              Re?
            </span>
          </h1>
          
          <p class="text-sm md:text-base font-sans text-white/85 font-light leading-relaxed drop-shadow-[0_2px_4px_rgba(0,0,0,0.7)] pt-8 max-w-2xl mx-auto">
            Numerosi sfidanti, imprevisti pronti a stravolgere gli incontri. Segui gli scontri dal 28 giugno al 10 luglio.
          </p>

          {/* SCRITTA AD EFFETTO INGRANDITA E ENTRAMBE IN ORO */}
          <div class="pt-8 space-y-2 text-sm md:text-base lg:text-lg font-mono uppercase tracking-[0.3em] text-center select-none">
            <p class="text-[#d4af37]/90 font-medium drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]">
              Non è solo calcetto
            </p>
            <p class="text-[#ffea00] font-black tracking-[0.35em] filter drop-shadow-[0_0_15px_rgba(255,234,0,0.5)] text-base md:text-lg lg:text-xl pt-0.5">
              È la Matenano Kings Cup
            </p>
          </div>
        </div>
      </div>

      {/* REINDIRIZZAMENTO BOTTONI PRINCIPALI */}
      <div class="flex flex-wrap justify-center gap-5 pt-6">
        <a 
          href="/classifiche" 
          class="px-10 py-4 bg-[#ffea00] text-black font-display font-black uppercase text-sm tracking-widest rounded-full hover:bg-white hover:scale-105 transition-all shadow-[0_0_35px_rgba(255,234,0,0.6)] animate-[pulse_2s_infinite]"
        >
          Tabellone Match
        </a>
        <a 
          href="#esplora" 
          class="px-10 py-4 bg-black/40 backdrop-blur-sm border border-white/20 text-white font-display font-black uppercase text-sm tracking-widest rounded-full hover:border-[#ffea00] hover:text-[#ffea00] hover:bg-[#ffea00]/5 transition-all"
        >
          Esplora Sezioni
        </a>
      </div>

      <hr class="border-white/5 max-w-xl mx-auto my-4" />

      {/* SEZIONE ESPLORA IL TORNEO */}
      <div id="esplora" class="space-y-10 pt-2">
        <div class="text-left">
          <span class="font-mono text-xs uppercase tracking-widest text-[#ffea00]/70 font-bold">LA COMPETIZIONE</span>
          <h2 class="text-3xl md:text-4xl font-display font-black uppercase tracking-wider mt-1 drop-shadow-sm">
            Esplora il Torneo
          </h2>
          <div class="w-16 h-1 bg-[#ffea00] mt-3"></div>
        </div>

        {/* 3 BOX STRUTTURATI */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          {/* BOX 1 */}
          <div class="bg-[#121210]/95 backdrop-blur-md border border-white/5 rounded-2xl p-6 flex flex-col justify-between space-y-6 hover:border-[#ffea00]/40 transition-all shadow-2xl group">
            <div class="space-y-3">
              <h3 class="text-xl font-display font-black uppercase tracking-wider text-[#ffea00]">
                Carte Speciali
              </h3>
              <p class="text-sm font-mono text-white/70 leading-relaxed">
                Scopri i bonus strategici e i malus ufficiali che le squadre possono pescare e giocare durante la partita.
              </p>
            </div>
            <a 
              href="/iltorneo" 
              class="w-full text-center py-2.5 bg-[#292923] text-[#ffea00] group-hover:bg-[#ffea00] group-hover:text-black font-display font-black uppercase text-xs tracking-widest rounded-xl transition-all"
            >
              Vai
            </a>
          </div>

          {/* BOX 2 */}
          <div class="bg-[#121210]/95 backdrop-blur-md border border-white/5 rounded-2xl p-6 flex flex-col justify-between space-y-6 hover:border-[#ffea00]/40 transition-all shadow-2xl group">
            <div class="space-y-3">
              <h3 class="text-xl font-display font-black uppercase tracking-wider text-[#ffea00]">
                Statistiche e Match
              </h3>
              <p class="text-sm font-mono text-white/70 leading-relaxed">
                Segui il posizionamento dei gironi, i punti delle squadre, i risultati dei match, marcatori e classifiche MVP.
              </p>
            </div>
            <a 
              href="/classifiche" 
              class="w-full text-center py-2.5 bg-[#292923] text-[#ffea00] group-hover:bg-[#ffea00] group-hover:text-black font-display font-black uppercase text-xs tracking-widest rounded-xl transition-all"
            >
              Vai
            </a>
          </div>

          {/* BOX 3 */}
          <div class="bg-[#121210]/95 backdrop-blur-md border border-white/5 rounded-2xl p-6 flex flex-col justify-between space-y-6 hover:border-[#ffea00]/40 transition-all shadow-2xl group">
            <div class="space-y-3">
              <h3 class="text-xl font-display font-black uppercase tracking-wider text-[#ffea00]">
                Albo d'Oro
              </h3>
              <p class="text-sm font-mono text-white/70 leading-relaxed">
                Ripercorri la storia del torneo, i vincitori delle scorse edizioni e le leggende che hanno alzato la coppa.
              </p>
            </div>
            <a 
              href="/albo" 
              class="w-full text-center py-2.5 bg-[#292923] text-[#ffea00] group-hover:bg-[#ffea00] group-hover:text-black font-display font-black uppercase text-xs tracking-widest rounded-xl transition-all"
            >
              Vai
            </a>
          </div>

        </div>
      </div>

    </div>
  </main>
</MkcLayout>

<style is:inline>
  /* Importazione del font Spectral SC da Google Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Spectral+SC:wght@700;800&display=swap');

  .text-regale {
    font-family: 'Spectral SC', Georgia, serif;
  }

  @keyframes shine {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  /* Riflesso oro-argenteo per il testo d'apertura */
  .text-shine-silver-gold {
    background: linear-gradient(
      110deg,
      #d4af37 10%,
      #e5e7eb 30%,
      #ffffff 50%,
      #e5e7eb 70%,
      #d4af37 90%
    );
    background-size: 200% auto;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shine 6s linear infinite;
  }

  /* Riflesso oro puro vibrante per la parola RE? */
  .text-shine-re {
    background: linear-gradient(
      110deg,
      #ffea00 10%,
      #fffeb3 40%,
      #ffffff 50%,
      #fffeb3 60%,
      #ffea00 90%
    );
    background-size: 200% auto;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shine 3.5s linear infinite;
  }
</style>